#include <iostream>

using namespace std;

void solve() {
    int n;
    cin >> n;
    
    int low = 1;
    int high = n + 1; 
    for (int i = 0; i < n; ++i) {
        cout << low << " " << high << " " << high + 1 << " ";
        low += 1;
        high += 2;
    }
    cout << "\n";
}

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);
    
    int t;
    cin >> t;
    while (t--) {
        solve();
    }
    
    return 0;
}
