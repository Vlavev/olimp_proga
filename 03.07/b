#include <iostream>
#include <vector>
#include <algorithm>

using namespace std;

void solve() {
    long long n;
    int k;
    cin >> n >> k;
    
    vector<int> a(k);
    for (int i = 0; i < k; ++i) {
        cin >> a[i];
    }
    
    sort(a.begin(), a.end());
    
    long long ops = 0;
    for (int i = 0; i < k - 1; ++i) {
        if (a[i] == 1) {
            ops += 1; 
        } else {
            ops += (a[i] - 1) + a[i]; 
        }
    }
    
    cout << ops << "\n";
}

int main() {
    int t;
    cin >> t;
    while (t--) {
        solve();
    }
    return 0;
}
