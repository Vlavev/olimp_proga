#include <iostream>
#include <algorithm>

using namespace std;

void solve() {
    int a, b, c;
    cin >> a >> b >> c;
    
    int max_bananas = 0;
    
    for (int i = 0; i <= 5; ++i) {
        for (int j = 0; j <= 5; ++j) {
            for (int k = 0; k <= 5; ++k) {
                if (i + j + k <= 5) {
                    int cur_a = a + i;
                    int cur_b = b + j;
                    int cur_c = c + k;
                    max_bananas = max(max_bananas, cur_a * cur_b * cur_c);
                }
            }
        }
    }
    
    cout << max_bananas << "\n";
}

int main() {
    int t;
    cin >> t;
    while (t--) {
        solve();
    }
    return 0;
}
