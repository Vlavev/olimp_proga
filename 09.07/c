#include <iostream>
#include <vector>
#include <numeric>

using namespace std;

void solve() {
    int num_ships;
    long long total_attacks;
    cin >> num_ships >> total_attacks;

    vector<int> durability(num_ships);
    long long sum_durability = 0;
    for (int i = 0; i < num_ships; ++i) {
        cin >> durability[i];
        sum_durability += durability[i];
    }

    if (total_attacks >= sum_durability) {
        cout << num_ships << "\n";
        return;
    }

    long long left_attacks = (total_attacks + 1) / 2;
    long long right_attacks = total_attacks / 2;

    int left_ptr = 0;
    int right_ptr = num_ships - 1;
    int sunken_count = 0;

    while (left_ptr <= right_ptr && left_attacks >= durability[left_ptr]) {
        left_attacks -= durability[left_ptr];
        sunken_count++;
        left_ptr++;
    }

    while (left_ptr <= right_ptr && right_attacks >= durability[right_ptr]) {
        right_attacks -= durability[right_ptr];
        sunken_count++;
        right_ptr--;
    }

    cout << sunken_count << "\n";
}

int main() {
    int test_cases;
    if (cin >> test_cases) {
        while (test_cases--) {
            solve();
        }
    }
    return 0;
}
