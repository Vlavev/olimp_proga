#include <iostream>
#include <vector>

using namespace std;

int main() {
    int n, k, m;
    cin >> n >> k >> m;

    vector<bool> danger(n + 1, false);
    for (int i = 0; i < m; ++i) {
        int a;
        cin >> a;
        danger[a] = true;
    }

    vector<long long> dp(n + 1, 0);
    dp[0] = 1;

    for (int i = 1; i <= n; ++i) {
        if (danger[i]) {
            dp[i] = 0;
            continue;
        }
        for (int j = 1; j <= k; ++j) {
            if (i - j >= 0) {
                dp[i] = (dp[i] + dp[i - j]) % 1000000007;
            }
        }
    }

    cout << dp[n] << "\n";
    return 0;
}
