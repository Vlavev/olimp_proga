#include <iostream>
#include <vector>

using namespace std;

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    int n, m, k;
    if (!(cin >> n >> m >> k)) return 0;

    vector<vector<bool>> is_bad(n + 1, vector<bool>(m + 1, false));
    for (int i = 0; i < k; ++i) {
        int x, y;
        cin >> x >> y;
        is_bad[x][y] = true;
    }

    vector<int> dp(m + 1, 0);
    dp[0] = 1;

    for (int i = 0; i <= n; ++i) {
        for (int j = 0; j <= m; ++j) {
            if (is_bad[i][j]) {
                dp[j] = 0;
            } else {
                if (j > 0) {
                    dp[j] = (dp[j] + dp[j - 1]) % 1000000007;
                }
            }
        }
    }

    cout << dp[m] << "\n";
    return 0;
}
