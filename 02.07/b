#include <iostream>
#include <vector>

using namespace std;

int main() {
    int l, r;
    cin >> l >> r;

    vector<long long> dp(r + 1, 0);
    dp[1] = 1;

    for (int i = 1; i <= r; ++i) {
        for (int j = 2 * i; j <= r; j += i) {
            dp[j] = (dp[j] + dp[i]) % 1000000007;
        }
    }

    long long total_paths = 0;
    for (int i = l; i <= r; ++i) {
        total_paths = (total_paths + dp[i]) % 1000000007;
    }

    cout << total_paths << "\n";
    return 0;
}
