#include <iostream>
#include <vector>
#include <algorithm>

using namespace std;

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    int n, m;
    if (!(cin >> n >> m)) return 0;

    vector<vector<int>> grid(n, vector<int>(m));
    for (int i = 0; i < n; ++i) {
        for (int j = 0; j < m; ++j) {
            cin >> grid[i][j];
        }
    }

    vector<vector<int>> dp(n, vector<int>(m, 0));
    dp[0][0] = grid[0][0];

    for (int i = 0; i < n; ++i) {
        for (int j = 0; j < m; ++j) {
            if (i == 0 && j == 0) continue;
            int option1 = (i > 0) ? dp[i - 1][j] : -1;
            int option2 = (j > 0) ? dp[i][j - 1] : -1;
            dp[i][j] = grid[i][j] + max(option1, option2);
        }
    }

    cout << dp[n - 1][m - 1] << "\n";
    return 0;
}
