#include <iostream>
#include <string>
#include <vector>
#include <algorithm>

using namespace std;

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    string a, b;
    if (!(cin >> a >> b)) return 0;

    if (a.length() != b.length()) {
        cout << -1 << "\n";
        return 0;
    }

    int n = a.length();
    
    string s = b + "#" + a + a;
    int m = s.length();
    vector<int> z(m, 0);

    int l = 0, r = 0;
    for (int i = 1; i < m; ++i) {
        if (i <= r) {
            z[i] = min(r - i + 1, z[i - l]);
        }
        while (i + z[i] < m && s[z[i]] == s[i + z[i]]) {
            z[i]++;
        }
        if (i + z[i] - 1 > r) {
            l = i;
            r = i + z[i] - 1;
        }
    }

    for (int i = n + 1; i <= 2 * n; ++i) {
        if (z[i] >= n) {
            int pos = i - (n + 1); 
            int right_shift = (n - pos) % n;
            cout << right_shift << "\n";
            return 0;
        }
    }

    cout << -1 << "\n";
    return 0;
}
