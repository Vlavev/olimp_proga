#include <iostream>
#include <vector>
#include <algorithm>

using namespace std;

int main() {
    int n, k;
    cin >> n >> k;
    
    vector<int> a(n);
    for (int i = 0; i < n; ++i) {
        cin >> a[i];
    }
    
    int max_xor = 0;
    
    for (int mask = 0; mask < (1 << n); ++mask) {
        if (__builtin_popcount(mask) == k) {
            int current_xor = 0;
            for (int i = 0; i < n; ++i) {
                if ((mask >> i) & 1) {
                    current_xor ^= a[i];
                }
            }
            max_xor = max(max_xor, current_xor);
        }
    }
    
    cout << max_xor << "\n";
    return 0;
}
